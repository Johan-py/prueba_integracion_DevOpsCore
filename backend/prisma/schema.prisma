generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ====================== ENUMS ======================

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO
}

enum EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO
}

enum EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA
}

enum Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum TipoMultimedia {
  IMAGEN
  VIDEO
}

enum TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER
}

enum TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG
}

// ====================== USUARIOS ======================

model Rol {
  id        Int       @id @default(autoincrement())
  nombre    RolNombre @unique

  usuarios  Usuario[]

  @@map("rol")
}

model Usuario {
  id              Int      @id @default(autoincrement())
  nombre          String
  apellido        String
  correo          String   @unique
  password        String
  pais            String?
  avatar          String?
  genero          Genero?
  direccion       String?
  activo          Boolean  @default(true)
  fechaRegistro   DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rolId           Int
  rol             Rol      @relation(fields: [rolId], references: [id])

  telefonos       Telefono[]
  sesiones        Sesion[]
  notificaciones  Notificacion[]
  cambioEmails    CambioEmail[]
  inmuebles       Inmueble[]
  perfil          Perfil?
  publicaciones   Publicacion[]
  visitas         Visitor[]

  @@index([correo])
  @@map("usuario")
}

// ====================== RELACIONADOS ======================

model Telefono {
  id          Int     @id @default(autoincrement())
  codigoPais  String
  numero      String
  principal   Boolean @default(false)

  usuarioId   Int
  usuario     Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("telefono")
}

model Sesion {
  id               Int      @id @default(autoincrement())
  token            String   @unique
  fechaInicio      DateTime @default(now())
  fechaExpiracion  DateTime
  estado           Boolean  @default(true)

  usuarioId        Int
  usuario          Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesion")
}

model Notificacion {
  id              Int      @id @default(autoincrement())
  titulo          String
  mensaje         String
  leida           Boolean  @default(false)
  fechaCreacion   DateTime @default(now())
  fechaLectura    DateTime?
  eliminada       Boolean  @default(false)

  usuarioId       Int
  usuario         Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificacion")
}

model CambioEmail {
  id             Int      @id @default(autoincrement())
  emailNuevo     String
  token          String   @unique
  expiraEn       DateTime
  creadoEn       DateTime @default(now())
  completadoEn   DateTime?

  usuarioId      Int
  usuario        Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("cambio_email")
}

// ====================== PERFIL (1:1) ======================

model Perfil {
  id             Int   @id @default(autoincrement())
  nombreCompleto String
  datos          Json?

  usuarioId      Int   @unique
  usuario        Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfil")
}